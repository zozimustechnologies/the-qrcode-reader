<svg xmlns="http://www.w3.org/2000/svg" width="640" height="400" viewBox="0 0 640 400">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#3d7ea6"/>
      <stop offset="100%" stop-color="#1a4a6e"/>
    </linearGradient>
  </defs>

  <!-- Browser chrome -->
  <rect width="640" height="400" rx="8" fill="#2b2b2b"/>
  <!-- Tab bar -->
  <rect x="0" y="0" width="640" height="24" rx="8" fill="#1e1e1e"/>
  <rect x="0" y="8" width="640" height="16" fill="#1e1e1e"/>
  <rect x="6" y="4" width="120" height="18" rx="6" fill="#2b2b2b"/>
  <circle cx="16" cy="13" r="4" fill="#3d7ea6"/>
  <text x="24" y="16" font-family="'Segoe UI', sans-serif" font-size="8" fill="#cccccc">QR Scanner</text>
  <!-- Window controls -->
  <circle cx="606" cy="12" r="4" fill="#ff5f57"/>
  <circle cx="620" cy="12" r="4" fill="#febc2e"/>
  <circle cx="634" cy="12" r="4" fill="#28c840"/>
  <!-- URL bar -->
  <rect x="0" y="24" width="640" height="24" fill="#323232"/>
  <rect x="100" y="28" width="440" height="16" rx="8" fill="#1e1e1e"/>
  <text x="118" y="40" font-family="'Segoe UI', sans-serif" font-size="8" fill="#888888">chrome-extension://qrcodereader/index.html</text>

  <!-- Page content -->
  <rect x="0" y="48" width="640" height="352" fill="url(#bgGrad)"/>

  <!-- Center card -->
  <g transform="translate(170, 68)">
    <rect width="300" height="320" rx="12" fill="transparent"/>

    <!-- Header -->
    <rect x="80" y="0" width="24" height="24" rx="5" fill="rgba(255,255,255,0.15)"/>
    <rect x="84" y="4" width="16" height="16" rx="3" fill="#ffffff" opacity="0.8"/>
    <text x="110" y="18" font-family="'Segoe UI', Roboto, sans-serif" font-size="14" font-weight="700" fill="#ffffff">Scan QR Codes</text>

    <!-- Donate button -->
    <rect x="240" y="2" width="60" height="20" rx="10" fill="#e53935"/>
    <text x="249" y="16" font-family="'Segoe UI', Roboto, sans-serif" font-size="8" font-weight="600" fill="#ffffff">♥ Donate</text>

    <!-- Scanner card -->
    <rect x="0" y="32" width="300" height="240" rx="10" fill="#ffffff"/>

    <!-- Scanner area -->
    <rect x="14" y="44" width="272" height="160" rx="8" fill="#f5f5f5" stroke="rgba(0,0,0,0.08)" stroke-width="0.5"/>

    <!-- Camera icon -->
    <text x="118" y="140" font-family="'Segoe UI', sans-serif" font-size="36" fill="rgba(61,126,166,0.4)">📷</text>

    <!-- Camera button -->
    <rect x="70" y="160" width="160" height="24" rx="6" fill="#3d7ea6"/>
    <text x="82" y="176" font-family="'Segoe UI', Roboto, sans-serif" font-size="9" font-weight="500" fill="#ffffff">Request Camera Permissions</text>

    <!-- Link -->
    <text x="100" y="200" font-family="'Segoe UI', sans-serif" font-size="9" fill="#1d9bf0">Scan an Image File</text>

    <!-- Result -->
    <rect x="0" y="220" width="300" height="32" rx="8" fill="#ffffff" stroke="rgba(0,0,0,0.06)" stroke-width="0.5"/>
    <text x="14" y="240" font-family="'Segoe UI', Roboto, sans-serif" font-size="9" fill="#333333">The result is:</text>

    <!-- Footer -->
    <text x="75" y="290" font-family="'Segoe UI', Roboto, sans-serif" font-size="8" fill="rgba(255,255,255,0.7)">© 2026 Zozimus Technologies</text>
  </g>
</svg>
