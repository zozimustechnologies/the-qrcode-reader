{
  "manifest_version": 3,
  "name": "QR Code Reader",
  "description": "Scan and read QR codes",
  "version": "1.0",
  "permissions": [],
  "host_permissions": [
    "https://the-qrcode-reader.netlify.app/*"
  ],
  "action": {
    "default_title": "QR Code Reader"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/1.ico",
    "48": "images/1.ico",
    "128": "images/1.ico"
  }
}
